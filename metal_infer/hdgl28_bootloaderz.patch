index 0000000..3e2e0e4
--- /dev/null
+++ b/metal_infer/hdgl_bootloaderz.h
@@ -0,0 +1,85 @@
+// hdgl_bootloaderz.h — BootloaderZ V6.0 integration header for Flash-MoE HDGL-28
+// Exposes the APA/HDGL lattice API from bootloaderZ.c for use in infer.m / chat.m
+#pragma once
+#include <stdint.h>
+#include <stddef.h>
+#include <stdbool.h>
+
+// ── APA state flags ──────────────────────────────────────────────────────────
+#define APA_FLAG_SIGN_NEG  (1 << 0)
+#define APA_FLAG_IS_NAN    (1 << 1)
+#define APA_FLAG_GOI       (1 << 2)   // Gradual Overflow Infinity
+#define APA_FLAG_GUZ       (1 << 3)   // Gradual Underflow Zero
+
+// ── System constants (match bootloaderZ.c) ───────────────────────────────────
+#define BLZ_PHI            1.6180339887
+#define BLZ_MAX_INSTANCES  8388608
+#define BLZ_SLOTS_PER_INST 4
+#define BLZ_CHUNK_SIZE     1048576     // 1 M slots per chunk
+#define BLZ_MSB_MASK       (1ULL << 63)
+
+// ── MPI: arbitrarily-wide integer metadata ───────────────────────────────────
+typedef struct {
+    uint64_t *words;
+    size_t    num_words;
+    uint8_t   sign;        // 0 = positive, 1 = negative
+} MPI;
+
+// ── Slot4096: Arbitrary Precision Architecture slot ──────────────────────────
+typedef struct {
+    uint64_t  *mantissa_words;      // multi-word mantissa
+    MPI        num_words_mantissa;  // future-proof word count
+    MPI        exponent_mpi;        // future-proof exponent
+    uint16_t   exponent_base;       // target base (4096)
+    uint32_t   state_flags;
+    MPI        source_of_infinity;
+    size_t     num_words;           // legacy word count
+    int64_t    exponent;            // legacy base-2 exponent
+    float      base;                // φ-scaled dynamic base
+    int        bits_mant;           // mantissa bit-width (e.g. 4096)
+    int        bits_exp;            // exponent bit-width
+} Slot4096;
+
+// ── HDGLChunk / HDGLLattice ───────────────────────────────────────────────────
+typedef struct {
+    Slot4096 *slots;
+    size_t    allocated;
+} HDGLChunk;
+
+typedef struct {
