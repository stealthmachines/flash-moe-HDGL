+
+// Mock implementation for router feedback - maps lattice index to state fields
+HDGL_SlotState* hdgl_get_slot_state(int lattice_id) {
+    static HDGL_SlotState state;
+    Slot4096 *slot = lattice_get_slot(g_hdgl_lattice, lattice_id);
+    if (!slot) return NULL;
+
+    // Derive "charge/entropy/tension" from the APA mantissa words
+    uint64_t w = slot->mantissa_words[0];
+    state.charge = (uint32_t)(w & 0xFFFFFFFF);
+    state.entropy = (uint32_t)(w >> 32);
+    state.tension = (uint32_t)(slot->exponent & 0xFFFFFFFF);
+    
+    return &state;
+}
